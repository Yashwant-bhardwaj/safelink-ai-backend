PORT=5000
JWT_SECRET=safelink_jwt_secret_key_super_secure_change_in_production_xyz987
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Gemini AI ──────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Google OAuth ───────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── GitHub OAuth ───────────────────────────────────────────
# Get from: https://github.com/settings/developers
# Set callback URL to: http://localhost:5000/api/auth/github/callback
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE
